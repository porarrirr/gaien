rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedInOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isSignedInOwner(userId);

      match /sync/{docId} {
        allow read, write: if isSignedInOwner(userId);

        match /chunks/{chunkId} {
          allow read, write: if isSignedInOwner(userId);
        }
      }
    }
  }
}
